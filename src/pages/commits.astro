---
import { CommitCard } from "@components/features/commits";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCommitData, commitData } from "../data/commits";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";



const title = i18n(I18nKey.commits);

// 异步获取 commit 数据
let sortedCommits = commitData;
try {
	const commits = await getCommitData();
	// 按日期排序，最新的在前
	sortedCommits = [...commits].sort((a, b) => {
		return new Date(b.date).getTime() - new Date(a.date).getTime();
	});
} catch (error) {
	console.error("获取 commit 数据失败:", error);
	// 失败时使用静态数据
}

// 解析最新 commit 的 tags
const parseTagsFromMessage = (message: string | undefined | null) => {
	if (!message) {
		return [];
	}
	const tagsMatch = message.match(/tags:\s*\[(.*?)\]/);
	if (tagsMatch && tagsMatch[1]) {
		// 提取 tags 数组内容并去除引号和空格
		return tagsMatch[1]
			.split(",")
			.map(tag => tag.trim().replace(/^["']|["']$/g, ""))
			.filter(tag => tag.length > 0);
	}
	return [];
};

// 获取最新 commit 的 tags
const latestCommit = sortedCommits[0];

// 简化 latestTags 的计算过程
let latestTags: string[] = [];
if (latestCommit) {
	// 确保即使在开发环境中也能正确获取 tags
	if (latestCommit.tags && latestCommit.tags.length > 0) {
		latestTags = latestCommit.tags;
	} else {
		latestTags = parseTagsFromMessage(latestCommit.message);
	}
}

// 手动设置 latestTags 为静态数据中的 tags，用于测试
// latestTags = sortedCommits[0]?.tags || [];

// 构建 subtitle
let subtitle = "网站更新记录。/.由于平台API限制，更新时这个地方有时不显示，是正常现象。";
if (latestTags.length > 0) {
	subtitle += `\n最新版本: ${latestTags.join(", ")}`;
} else {
	subtitle += "\n最新版本: 空值（是不是忘记写了？awa）";
}
---

<MainGridLayout title={title} description={subtitle}>
	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="pb-4 card-base z-10 px-4 sm:px-9 py-8 relative w-full onload-animation">
			<h1 class="text-2xl font-bold text-black/90 dark:text-white/90">
				{title}
			</h1>
			<p class="text-sm text-black/50 dark:text-white/50">
				{subtitle}
			</p>

			<div class="mt-8">
				<div class="flex items-center justify-between mb-8">
					<h2 class="text-lg font-medium text-pink-700 dark:text-pink-300">
						最近提交
					</h2>
					<span class="text-sm text-pink-500 dark:text-purple-400">
						共 {sortedCommits.length} 条记录
					</span>
				</div>

				<div id="commits-list" class="markdown-content">
					{sortedCommits.map((commit, index) => (
						<CommitCard 
							item={commit} 
							isLatest={index === 0}
						/>
					))}
				</div>

				<div id="no-results" class="hidden text-center py-20">
					<p class="text-pink-400 dark:text-purple-500 text-lg">
						No matching commits
					</p>
				</div>
			</div>
		</div>
	</div>
	
	<!-- Swup 页面切换动画重载脚本 -->
	<script is:inline data-swup-reload-script>
		(function initCommitCardAnimations() {
			// 重置所有 commit-card 的动画
			function resetAnimations() {
				const cards = document.querySelectorAll('.commit-card');
				cards.forEach((card) => {
					// 移除动画类以重置
					card.style.animation = 'none';
					card.style.opacity = '0';
					
					// 强制重绘
					void card.offsetWidth;
					
					// 重新应用动画
					card.style.animation = '';
				});

				// 同时重置节点动画
				const nodes = document.querySelectorAll('.tree-node');
				nodes.forEach((node) => {
					node.style.animation = 'none';
					node.style.opacity = '0';
					void node.offsetWidth;
					node.style.animation = '';
				});

				// 重置标题动画
				const titles = document.querySelectorAll('[data-tag-title]');
				titles.forEach((title) => {
					title.style.animation = 'none';
					title.style.opacity = '0';
					void title.offsetWidth;
					title.style.animation = '';
				});
			}

			// 初始加载时执行
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', () => {
					setTimeout(resetAnimations, 50);
				});
			} else {
				setTimeout(resetAnimations, 50);
			}

			// Swup 页面切换后重新执行
			if (window.swup) {
				window.swup.hooks.on('page:view', () => {
					setTimeout(resetAnimations, 50);
				});
			} else {
				document.addEventListener('swup:enable', () => {
					if (window.swup) {
						window.swup.hooks.on('page:view', () => {
							setTimeout(resetAnimations, 50);
						});
					}
				});
			}

			// 兼容旧版 Swup 事件
			document.addEventListener('swup:contentReplaced', () => {
				setTimeout(resetAnimations, 50);
			});
			document.addEventListener('swup:content:replace', () => {
				setTimeout(resetAnimations, 50);
			});
		})();
	</script>
</MainGridLayout>

<style>
	#search-input {
		min-width: 200px;
	}

	.card-base {
		background: white;
		border: 1px solid rgba(236, 72, 153, 0.15);
		border-radius: 20px;
		box-shadow: 0 4px 12px rgba(236, 72, 153, 0.08);
		background-image: linear-gradient(135deg, rgba(255, 240, 245, 0.5), rgba(255, 255, 255, 0.8));
		font-family: 'ZenMaruGothic-Medium', '萝莉体 第二版', sans-serif;
	}

	@media (prefers-color-scheme: dark) {
		.card-base {
			background: rgba(30, 20, 40, 0.9);
			border-color: rgba(168, 85, 247, 0.2);
			box-shadow: 0 4px 12px rgba(168, 85, 247, 0.12);
			background-image: linear-gradient(135deg, rgba(50, 30, 60, 0.8), rgba(30, 20, 40, 0.9));
		}
	}
</style>
