---
import { commentConfig } from "@/config";
import { url } from "@/utils/url-utils";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<div id="tcomment"></div>
<!-- 使用自编译的 Twikoo 文件，避免点赞等按钮导致页面触发滚动回顶部 https://github.com/twikoojs/twikoo/issues/721 -->
<script is:inline src={url("/assets/js/twikoo.all.min.js")}></script>
<link rel="stylesheet" href={url("/assets/css/twikoo.css")} />
<link rel="stylesheet" href={url("/assets/css/twikoo-custom.css")} />
<script is:inline define:vars={{ config }}>
  // 存储 Twikoo 实例引用
  let twikooInstance = null;

  // 获取当前页面路径
  function getCurrentPath() {
    const pathname = window.location.pathname;
    return pathname.endsWith("/") && pathname.length > 1
      ? pathname.slice(0, -1)
      : pathname;
  }

  // 动态创建配置对象
  function createTwikooConfig() {
    return {
      ...config,
      path: getCurrentPath(),
      el: "#tcomment",
    };
  }

  // 清理 Twikoo 实例
  function cleanupTwikoo() {
    console.log('[Twikoo] 进入 cleanupTwikoo 函数');
    console.log('[Twikoo] 当前 twikooInstance:', twikooInstance);
    
    if (twikooInstance) {
      console.log('[Twikoo] 清理实例');
      
      // 尝试多种可能的销毁方法
      const destroyMethods = ['destroy', 'clear', 'dispose'];
      let destroyed = false;
      
      for (const method of destroyMethods) {
        if (typeof twikooInstance[method] === 'function') {
          try {
            console.log(`[Twikoo] 调用 ${method} 方法`);
            twikooInstance[method]();
            console.log(`[Twikoo] 实例已通过 ${method} 方法销毁`);
            destroyed = true;
            break;
          } catch (error) {
            console.error(`[Twikoo] 调用 ${method} 方法时出错:`, error);
          }
        }
      }
      
      if (!destroyed) {
        console.log('[Twikoo] 实例没有找到可用的销毁方法');
      }
      
      // 无论如何都将实例引用设为 null
      twikooInstance = null;
      console.log('[Twikoo] 实例引用已设为 null');
      
      // 清理 DOM
      const commentEl = document.getElementById("tcomment");
      if (commentEl) {
        commentEl.innerHTML = "";
        console.log('[Twikoo] DOM 已清理');
      }
    } else {
      console.log('[Twikoo] 没有实例需要清理');
    }
  }

  // 初始化 Twikoo
  function initTwikoo() {
    if (typeof twikoo !== "undefined") {
      const commentEl = document.getElementById("tcomment");
      if (commentEl) {
        // 先清理旧实例
        cleanupTwikoo();

        const dynamicConfig = createTwikooConfig();
        console.log("[Twikoo] 初始化配置（完成）");

        twikoo
          .init(dynamicConfig)
          .then((instance) => {
            // 保存实例引用
            twikooInstance = instance;
            console.log("[Twikoo] 初始化完成");
          })
          .catch((error) => {
            console.error("[Twikoo] 初始化失败:", error);
          });
      }
    } else {
      // 如果 Twikoo 未加载，稍后重试
      setTimeout(initTwikoo, 500);
    }
  }
  // 页面加载完成后初始化
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTwikoo);
  } else if (document.readyState === "interactive") {
    // DOM已解析完成，等待资源加载完成
    window.addEventListener("load", initTwikoo);
  } else {
    // 页面已完全加载完成
    initTwikoo();
  }

  // Swup 页面切换后重新初始化
  if (window.swup && window.swup.hooks) {
    window.swup.hooks.on("content:replace", function () {
      setTimeout(initTwikoo, 200);
    });
  } else {
    document.addEventListener("swup:enable", function () {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", function () {
          setTimeout(initTwikoo, 200);
        });
      }
    });
  }

  // 自定义事件监听
  document.addEventListener("firefly:page:loaded", function () {
    const commentEl = document.getElementById("tcomment");
    if (commentEl) {
      console.log("[Twikoo] 通过自定义事件重新初始化");
      initTwikoo();
    }
  });

  // 页面卸载时清理
  window.addEventListener('beforeunload', cleanupTwikoo);
</script>