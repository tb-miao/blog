---
import { commentConfig } from "@/config";

interface Props {
	path: string;
}

const config = {
	...commentConfig.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<div id="twikoo-container" class="twikoo-container">
	<div id="tcomment"></div>
</div>

<script is:inline define:vars={{ config }}>
	(function () {
		const TWIKOO_CONTAINER_ID = "twikoo-container";
		const TWIKOO_SCRIPT_URL = "/assets/js/twikoo.all.min.js";
		const ROOT_MARGIN = "200px";

		let observer = null;
		let twikooLoaded = false;

		function getCurrentPath() {
			const pathname = window.location.pathname;
			return pathname.endsWith("/") && pathname.length > 1
				? pathname.slice(0, -1)
				: pathname;
		}

		function createTwikooConfig() {
			return {
				...config,
				path: getCurrentPath(),
				el: "#tcomment",
			};
		}

		async function loadTwikooScript() {
			if (
				twikooLoaded ||
				document.getElementById("twikoo-script-loaded")
			) {
				console.log("[Twikoo] 脚本已加载");
				return;
			}
			console.log("[Twikoo] 开始加载脚本:", TWIKOO_SCRIPT_URL);
			return new Promise((resolve, reject) => {
				const script = document.createElement("script");
				script.id = "twikoo-script-loaded";
				script.src = TWIKOO_SCRIPT_URL;
				script.async = true;
				script.onload = () => {
					twikooLoaded = true;
					console.log("[Twikoo] 脚本加载成功");
					resolve();
				};
				script.onerror = (error) => {
					console.error("[Twikoo] 脚本加载失败:", error);
					reject(error);
				};
				document.head.appendChild(script);
			});
		}

		async function initTwikoo() {
			const commentEl = document.getElementById("tcomment");
			if (!commentEl) {
				return;
			}

			console.log("[Twikoo] 开始初始化");
			try {
				await loadTwikooScript();

				if (typeof twikoo === "undefined") {
					console.warn("[Twikoo] 脚本加载失败");
					return;
				}

				console.log("[Twikoo] 开始初始化评论");
				commentEl.innerHTML = "";
				const dynamicConfig = createTwikooConfig();
				console.log("[Twikoo] 初始化配置");
				await twikoo.init(dynamicConfig);
				console.log("[Twikoo] 初始化成功");
			} catch (error) {
				console.error("[Twikoo] 初始化失败:", error);
			}
		}

		/**
		 * 清理函数：用于释放资源和取消事件监听
		 * 在页面卸载前调用，防止内存泄漏
		 */
		function cleanup() {
			// 断开 IntersectionObserver 观察器
			if (observer) {
				observer.disconnect();
				observer = null;
			}
			// 移除 swup 的 content:replace 事件监听
			if (window.swup?.hooks) {
				window.swup.hooks.off("content:replace", initTwikoo);
			}
		}
		/**
		 * 设置懒加载：使用 IntersectionObserver 监听评论容器
		 * 当容器进入视口时自动加载 Twikoo 评论脚本
		 */
		function setupLazyLoad() {
			// 获取评论容器元素
			const container = document.getElementById(TWIKOO_CONTAINER_ID);
			if (!container) {
				console.warn("[Twikoo] 评论容器不存在");
				return;
			}

			// 创建 IntersectionObserver 监听容器是否进入视口
			observer = new IntersectionObserver(
				(entries) => {
					if (entries[0].isIntersecting && observer) {
						if (!document.getElementById(TWIKOO_CONTAINER_ID)) {
							console.warn("[Twikoo] 评论容器已不存在，取消初始化");
							observer.disconnect();
							observer = null;
							return;
						}
						observer.disconnect();
						observer = null;
						initTwikoo();
					}
				},
				{ rootMargin: ROOT_MARGIN },
			);

			observer.observe(container);
		}

		function setupSwupHooks() {
			if (window.swup?.hooks) {
				window.swup.hooks.on("content:replace", () => {
					setTimeout(setupLazyLoad, 200);
				});
			} else {
				document.addEventListener(
					"swup:enable",
					() => {
						if (window.swup?.hooks) {
							window.swup.hooks.on("content:replace", () => {
								setTimeout(setupLazyLoad, 200);
							});
						}
					},
					{ once: true },
				);
			}
		}

		document.addEventListener("mizuki:page:loaded", () => {
			setupLazyLoad();
		});

		// 在页面卸载前执行清理，释放资源防止内存泄漏
		window.addEventListener("beforeunload", cleanup);

		// 根据文档加载状态设置初始化逻辑
		if (document.readyState === "loading") {
			// 文档仍在加载中，等待 DOMContentLoaded 事件
			document.addEventListener("DOMContentLoaded", () => {
				setupLazyLoad();
				setupSwupHooks();
			});
		} else {
			// 文档已加载完成，直接执行初始化
			setupLazyLoad();
			setupSwupHooks();
		}
	})();
</script>

<style>
	.twikoo-container {
		min-height: 200px;
	}
</style>