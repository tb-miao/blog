---
import { Icon } from "astro-icon/components";
import Image from "@components/atoms/Image";
import type { CommitCardProps } from "./types";
import MarkdownIt from "markdown-it";

const { item, isLatest = false } = Astro.props as CommitCardProps & { isLatest?: boolean };

const GITHUB_OWNER = "tb-miao";
const GITHUB_REPO = "blog";

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleString("zh-CN", {
		year: "numeric",
		month: "short",
		day: "numeric",
		hour: "2-digit",
		minute: "2-digit",
		timeZone: "Asia/Shanghai"
	});
};

const getAuthorInitials = (author: string) => {
	return author.split(" ")
		.map(name => name[0])
		.join("")
		.toUpperCase()
		.slice(0, 2);
};

const parseTagsFromMessage = (message: string | undefined | null) => {
	if (!message) {
		return [];
	}
	const tagsMatch = message.match(/tags:\s*\[(.*?)\]/);
	if (tagsMatch && tagsMatch[1]) {
		return tagsMatch[1]
			.split(",")
			.map(tag => tag.trim().replace(/^["']|["']$/g, ""))
			.filter(tag => tag.length > 0);
	}
	return [];
};

const md = new MarkdownIt({ html: true, linkify: true, typographer: true });
const renderMarkdown = (text: string | undefined | null) => {
	if (!text) {
		return '';
	}
	const cleanedText = text.replace(/tags:\s*\[(.*?)\]/, '');
	return md.render(cleanedText);
};
---

<div
	class="commit-card group relative bg-transparent rounded-xl border border-black/10 dark:border-white/10 overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
>
	<div class="p-5">
		<div class="flex items-start gap-4">
			<div class="flex-shrink-0">
				<div class="w-12 h-12 rounded-xl overflow-hidden ring-2 ring-transparent group-hover:ring-[var(--primary)]/30 transition-all duration-300">
					{item.avatar ? (
						<Image
							src={item.avatar}
							alt={item.author}
							class="w-full h-full object-cover"
						/>
					) : (
						<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[var(--primary)]/20 to-[var(--primary)]/10">
							<span class="text-sm font-semibold text-[var(--primary)]">
								{getAuthorInitials(item.author)}
							</span>
						</div>
					)}
				</div>
			</div>

			<div class="flex-1 min-w-0">
				<div class="flex flex-col gap-3">
					<div class="flex items-start justify-between gap-3">
						<h3
							class="text-base font-medium text-black/90 dark:text-white/90 leading-relaxed group-hover:text-[var(--primary)] transition-colors duration-200"
							set:html={renderMarkdown(item.message)}
						/>
						{isLatest && (
							<span class="shrink-0 inline-flex items-center px-2 py-0.5 bg-[var(--primary)] text-white text-xs font-medium rounded-full animate-pulse">
								NEW
							</span>
						)}
					</div>

					<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-black/50 dark:text-white/50">
						<a
							href={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/commit/${item.hash}`}
							target="_blank"
							rel="noopener noreferrer"
							class="font-mono text-xs px-2 py-0.5 rounded-md bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 transition-colors duration-200"
						>
							{item.hash.slice(0, 7)}
						</a>

						<span class="flex items-center gap-1.5">
							<Icon name="material-symbols:person-outline" class="w-3.5 h-3.5" />
							<span>{item.author}</span>
						</span>

						<span class="flex items-center gap-1.5">
							<Icon name="material-symbols:schedule" class="w-3.5 h-3.5" />
							<span>{formatDate(item.date)}</span>
						</span>

						{item.branch && (
							<span class="flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--btn-regular-bg)] text-black/70 dark:text-white/70">
								<Icon name="material-symbols:merge-type" class="w-3.5 h-3.5" />
								<span class="text-xs font-medium">{item.branch}</span>
							</span>
						)}

						{(() => {
							const tags = parseTagsFromMessage(item.message);
							return (
								<span class="flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--btn-regular-bg)] text-black/70 dark:text-white/70">
									<Icon name="material-symbols:label-outline" class="w-3.5 h-3.5" />
									<span class="text-xs font-medium">{tags.length > 0 ? tags.join(", ") : "空值"}</span>
								</span>
							);
						})()}
					</div>

					<div class="flex items-center gap-4 text-xs font-medium">
						<span class="flex items-center gap-1 text-green-600 dark:text-green-400">
							<Icon name="material-symbols:add-rounded" class="w-4 h-4" />
							<span class="tabular-nums">{item.changes.additions}</span>
						</span>
						<span class="flex items-center gap-1 text-red-500 dark:text-red-400">
							<Icon name="material-symbols:remove-rounded" class="w-4 h-4" />
							<span class="tabular-nums">{item.changes.deletions}</span>
						</span>
					</div>
				</div>
			</div>
		</div>

		{item.files && item.files.length > 0 && (
			<div class="mt-4 pt-4 border-t border-black/5 dark:border-white/5">
				<div class="flex flex-wrap gap-2">
					{item.files.map((file) => (
						<span class="inline-flex items-center gap-1.5 text-xs text-black/60 dark:text-white/60 bg-[var(--btn-regular-bg)] px-2.5 py-1.5 rounded-md hover:bg-[var(--btn-regular-bg-hover)] transition-colors duration-200">
							<Icon name="material-symbols:description-outline" class="w-3.5 h-3.5 flex-shrink-0" />
							<span class="truncate max-w-[200px]">{file}</span>
						</span>
					))}
				</div>
			</div>
		)}
	</div>

	<div
		class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none rounded-xl"
	>
	</div>
</div>

<style>
	.commit-card {
		animation: fadeInUp 0.5s ease-out forwards;
		opacity: 0;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.commit-card:nth-child(1) { animation-delay: 0.05s; }
	.commit-card:nth-child(2) { animation-delay: 0.1s; }
	.commit-card:nth-child(3) { animation-delay: 0.15s; }
	.commit-card:nth-child(4) { animation-delay: 0.2s; }
	.commit-card:nth-child(5) { animation-delay: 0.25s; }
	.commit-card:nth-child(6) { animation-delay: 0.3s; }
	.commit-card:nth-child(7) { animation-delay: 0.35s; }
	.commit-card:nth-child(8) { animation-delay: 0.4s; }

	.commit-card :global(h3 p) {
		margin: 0;
	}

	.commit-card :global(h3 code) {
		background-color: var(--primary);
		color: white;
		padding: 0.125rem 0.375rem;
		border-radius: 0.25rem;
		font-size: 0.75rem;
		font-weight: 500;
	}
</style>
