---
import { Icon } from "astro-icon/components";
import Image from "@components/atoms/Image";
import type { CommitCardProps } from "./types";
import MarkdownIt from "markdown-it";

const { item, isLatest = false } = Astro.props as CommitCardProps & { isLatest?: boolean };

// GitHub 仓库信息
const GITHUB_OWNER = "tb-miao";
const GITHUB_REPO = "blog";

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	// 确保使用 UTC 时区，与 GitHub API 返回的时间一致
	return date.toLocaleString("zh-CN", {
		year: "numeric",
		month: "short",
		day: "numeric",
		hour: "2-digit",
		minute: "2-digit",
		timeZone: "UTC"
	});
};

const getAuthorInitials = (author: string) => {
	return author.split(" ")
		.map(name => name[0])
		.join("")
		.toUpperCase()
		.slice(0, 2);
};

// 解析 commit message 中的 tags:[] 语法
const parseTagsFromMessage = (message: string) => {
	const tagsMatch = message.match(/tags:\s*\[(.*?)\]/);
	if (tagsMatch && tagsMatch[1]) {
		// 提取 tags 数组内容并去除引号和空格
		return tagsMatch[1]
			.split(",")
			.map(tag => tag.trim().replace(/^["']|['"]$/g, ""))
			.filter(tag => tag.length > 0);
	}
	return [];
};

// 使用 markdown-it 渲染 markdown 内容
const md = new MarkdownIt({ html: true, linkify: true, typographer: true });
const renderMarkdown = (text: string) => {
	// 移除 tags:[] 语法，避免在渲染时显示
	const cleanedText = text.replace(/tags:\s*\[(.*?)\]/, '');
	return md.render(cleanedText);
};
---

<div class="commit-card border border-pink-100 dark:border-purple-700 rounded-2xl p-5 hover:bg-pink-50 dark:hover:bg-purple-900/20 transition-all duration-300">
	<div class="flex items-start gap-5">
		<div class="flex-shrink-0">
			<div class="w-14 h-14 rounded-full flex items-center justify-center overflow-hidden bg-gradient-to-br from-pink-100 to-purple-100 dark:from-purple-800/50 dark:to-pink-800/50 border-2 border-pink-200 dark:border-purple-600 shadow-sm">
				{item.avatar ? (
					<Image 
						src={item.avatar} 
						alt={item.author} 
						class="w-full h-full object-cover"
					/>
				) : (
					<span class="text-sm font-medium text-pink-600 dark:text-pink-300">
						{getAuthorInitials(item.author)}
					</span>
				)}
			</div>
		</div>
		<div class="flex-1 min-w-0">
			<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2 mb-3">
				<div>
					<h3 class="text-base font-medium text-pink-700 dark:text-pink-300 mb-1.5 leading-relaxed" set:html={renderMarkdown(item.message)}></h3>
					<div class="flex flex-wrap items-center gap-2 text-sm text-pink-500 dark:text-purple-400">
						<div class="flex items-center gap-1.5">
							{isLatest && (
								<span class="inline-flex items-center justify-center px-2 py-0.5 bg-pink-500 text-white text-xs font-medium rounded-full animate-pulse">
									NEW
								</span>
							)}
							<a href={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/commit/${item.hash}`} target="_blank" rel="noopener noreferrer" class="font-mono text-xs bg-pink-100 dark:bg-purple-800/30 px-2 py-0.5 rounded-full hover:bg-pink-200 dark:hover:bg-purple-700/50 transition-colors duration-200">
								{item.hash.slice(0, 7)}
							</a>
						</div>
						<span>by {item.author}</span>
						<span>•</span>
						<span>{formatDate(item.date)}</span>
						{item.branch && (
									<span class="flex items-center gap-1 ml-2 px-2 py-0.5 bg-pink-100 dark:bg-purple-800/30 rounded-full">
										<Icon name="material-symbols:merge-type" class="w-3 h-3" />
										<span class="text-xs font-medium">{item.branch}</span>
									</span>
								)}
								{(() => {
									const tags = parseTagsFromMessage(item.message);
									return (
										<span class="flex items-center gap-1 ml-2 px-2 py-0.5 bg-pink-100 dark:bg-purple-800/30 rounded-full">
											<Icon name="material-symbols:label" class="w-3 h-3" />
											<span class="text-xs font-medium">{tags.length > 0 ? tags.join(", ") : "空值"}</span>
										</span>
									);
								})()}
					</div>
				</div>
				<div class="flex items-center gap-4 text-xs font-medium">
					<span class="text-green-500 dark:text-green-400 flex items-center gap-1">
						<Icon name="material-symbols:add" class="w-3 h-3" />
						{item.changes.additions}
					</span>
					<span class="text-red-500 dark:text-red-400 flex items-center gap-1">
						<Icon name="material-symbols:remove" class="w-3 h-3" />
						{item.changes.deletions}
					</span>
				</div>
			</div>
			{item.files && item.files.length > 0 && (
				<div class="mt-3 pt-3 border-t border-pink-100 dark:border-purple-800/50">
					<div class="flex flex-wrap gap-2">
						{item.files.map((file) => (
							<div class="flex items-center gap-1.5 text-xs text-pink-600 dark:text-purple-400 bg-pink-50 dark:bg-purple-800/20 px-2.5 py-1.5 rounded-full">
								<Icon name="material-symbols:description" class="w-3 h-3 flex-shrink-0" />
								<span class="truncate max-w-[220px]">{file}</span>
							</div>
						))}
					</div>
				</div>
			)}
		</div>
	</div>
</div>

<style>
	.commit-card {
		transition: all 0.3s ease;
		border-radius: 16px;
		font-family: 'ZenMaruGothic-Medium', '萝莉体 第二版', sans-serif;
	}

	.commit-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 6px 16px rgba(236, 72, 153, 0.12);
		border-color: rgba(236, 72, 153, 0.25);
	}

	@media (prefers-color-scheme: dark) {
		.commit-card:hover {
			box-shadow: 0 6px 16px rgba(168, 85, 247, 0.2);
			border-color: rgba(168, 85, 247, 0.35);
		}
	}
</style>
