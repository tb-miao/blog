---
import { Icon } from "astro-icon/components";
import type { CommitCardProps, CommitItem } from "./types";
import MarkdownIt from "markdown-it";

const { item, isLatest = false } = Astro.props as CommitCardProps;

const GITHUB_OWNER = "tb-miao";
const GITHUB_REPO = "blog";

const formatDate = (dateString: string) => {
	const date = new Date(dateString);
	return date.toLocaleString("zh-CN", {
		year: "numeric",
		month: "short",
		day: "numeric",
		hour: "2-digit",
		minute: "2-digit",
		timeZone: "Asia/Shanghai"
	});
};

const getAuthorInitials = (author: string) => {
	return author.split(" ")
		.map(name => name[0])
		.join("")
		.toUpperCase()
		.slice(0, 2);
};

const parseTagsFromMessage = (message: string | undefined | null) => {
	if (!message) {
		return [];
	}
	const tagsMatch = message.match(/tags:\s*\[(.*?)\]/);
	if (tagsMatch && tagsMatch[1]) {
		return tagsMatch[1]
			.split(",")
			.map(tag => tag.trim().replace(/^["']|["']$/g, ""))
			.filter(tag => tag.length > 0);
	}
	return [];
};

const md = new MarkdownIt({ html: true, linkify: true, typographer: true });
const renderMarkdown = (text: string | undefined | null) => {
	if (!text) {
		return '';
	}
	const cleanedText = text.replace(/tags:\s*\[(.*?)\]/, '');
	return md.render(cleanedText);
};


const renderTagsAsH1 = (item: CommitItem) => {
	// 优先使用 item.tags，如果没有则从 message 中解析
	const tags = item.tags && item.tags.length > 0 
		? item.tags 
		: parseTagsFromMessage(item.message);
	
	if (tags.length === 0) {
		return '';
	}
	return tags.map(tag => {
		return `<h1 class="commit-tag-title" data-tag-title>${tag}</h1>`;
	}).join('');
};
---

<div
	class="commit-card group relative bg-transparent rounded-[var(--radius-large)] overflow-hidden"
>
	<div class="p-5">
		<div class="flex items-start gap-4">
			<!-- Git 树状时间线 -->
			<div class="git-tree-line flex-shrink-0 flex flex-col items-center w-8">
				<!-- 上方连接线 - 始终显示 -->
				<div class="tree-line-vertical w-0.5 h-6 bg-gradient-to-b from-[var(--primary)]/50 to-[var(--primary)]/30"></div>
				
				<!-- 节点圆点 -->
				<div class={`
					tree-node group relative flex items-center justify-center w-5 h-5 rounded-full 
					transition-all duration-300 cursor-pointer z-10
					${isLatest 
						? 'bg-[var(--primary)] ring-4 ring-[var(--primary)]/20' 
						: 'bg-[var(--card-bg)] ring-2 ring-[var(--primary)] hover:ring-4 hover:ring-[var(--primary)]/30'
					}
				`}>
					<div class={`
						w-2.5 h-2.5 rounded-full
						${isLatest ? 'bg-[var(--card-bg)]' : 'bg-[var(--primary)]'}
					`}></div>
				</div>
				
				<!-- 下方连接线 - 始终显示 -->
				<div class="tree-line-vertical flex-1 min-h-[40px] w-0.5 bg-gradient-to-b from-[var(--primary)]/30 to-[var(--primary)]/50"></div>
			</div>

			<div class="flex-shrink-0">
				<div class="w-12 h-12 rounded-xl overflow-hidden ring-2 ring-transparent group-hover:ring-[var(--primary)]/30 transition-all duration-300">
					{item.avatar ? (
						<img
							src={item.avatar}
							alt={item.author}
							class="w-full h-full object-cover"
						/>
					) : (
						<div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[var(--primary)]/20 to-[var(--primary)]/10">
							<span class="text-sm font-semibold text-[var(--primary)]">
								{getAuthorInitials(item.author)}
							</span>
						</div>
					)}
				</div>
			</div>

			<div class="flex-1 min-w-0">
				<div class="flex flex-col gap-3">
					{renderTagsAsH1(item) && (
						<div set:html={renderTagsAsH1(item)} />
					)}
					<div class="flex items-start justify-between gap-3">
						<h3
							class="text-base font-medium text-[var(--deep-text)] leading-relaxed group-hover:text-[var(--primary)] transition-colors duration-200 break-words overflow-wrap-anywhere"
							set:html={renderMarkdown(item.message)}
						/>
						{isLatest && (
							<span class="shrink-0 inline-flex items-center px-2 py-0.5 bg-[var(--primary)] text-[var(--card-bg)] text-xs font-medium rounded-full">
								NEW
							</span>
						)}
					</div>

					<div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-[var(--content-meta)]">
						<a
							href={`https://github.com/${GITHUB_OWNER}/${GITHUB_REPO}/commit/${item.hash}`}
							target="_blank"
							rel="noopener noreferrer"
							class="font-mono text-xs px-2 py-0.5 rounded-md bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)]/20 transition-colors duration-200"
						>
							{item.hash.slice(0, 7)}
						</a>

						<span class="flex items-center gap-1.5">
							<Icon name="material-symbols:person-outline" class="w-3.5 h-3.5" />
							<span>{item.author}</span>
						</span>

						<span class="flex items-center gap-1.5">
							<Icon name="material-symbols:schedule" class="w-3.5 h-3.5" />
							<span>{formatDate(item.date)}</span>
						</span>

						{item.branch && (
							<span class="flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--btn-regular-bg)] text-[var(--btn-content)]">
								<Icon name="material-symbols:merge-type" class="w-3.5 h-3.5" />
								<span class="text-xs font-medium">{item.branch}</span>
							</span>
						)}

						{(() => {
							const tags = item.tags && item.tags.length > 0 ? item.tags : parseTagsFromMessage(item.message);
							return (
								<span class="flex items-center gap-1 px-2 py-0.5 rounded-md bg-[var(--btn-regular-bg)] text-[var(--btn-content)]">
									<Icon name="material-symbols:label-outline" class="w-3.5 h-3.5" />
									<span class="text-xs font-medium">{tags.length > 0 ? tags.join(", ") : "空值"}</span>
								</span>
							);
						})()}
					</div>

					<div class="flex items-center gap-4 text-xs font-medium">
						<span class="flex items-center gap-1 text-green-600 dark:text-green-400">
							<Icon name="material-symbols:add-rounded" class="w-4 h-4" />
							<span class="tabular-nums">{item.changes.additions}</span>
						</span>
						<span class="flex items-center gap-1 text-red-500 dark:text-red-400">
							<Icon name="material-symbols:remove-rounded" class="w-4 h-4" />
							<span class="tabular-nums">{item.changes.deletions}</span>
						</span>
					</div>
				</div>
			</div>
		</div>

		{item.files && item.files.length > 0 && (
			<div class="mt-4 pt-4 border-t border-[var(--line-divider)]">
				<div class="flex flex-wrap gap-2">
					{item.files.map((file) => (
						<span class="inline-flex items-center gap-1.5 text-xs text-[var(--content-meta)] bg-[var(--btn-regular-bg)] px-2.5 py-1.5 rounded-md hover:bg-[var(--btn-regular-bg-hover)] transition-colors duration-200">
							<Icon name="material-symbols:description-outline" class="w-3.5 h-3.5 flex-shrink-0" />
							<span class="truncate max-w-[200px]">{file}</span>
						</span>
					))}
				</div>
			</div>
		)}
	</div>
</div>

<style>
	/* ========== 入场动画 ========== */
	.commit-card {
		animation: cascadeIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
		opacity: 0;
		transform: translateY(30px) scale(0.95);
	}

	@keyframes cascadeIn {
		0% {
			opacity: 0;
			transform: translateY(30px) scale(0.95);
		}
		60% {
			transform: translateY(-5px) scale(1.01);
		}
		100% {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	/* 级联动画延迟 - 依次显示效果 */
	.commit-card:nth-child(1) { animation-delay: calc(var(--content-delay, 0ms) + 80ms); }
	.commit-card:nth-child(2) { animation-delay: calc(var(--content-delay, 0ms) + 160ms); }
	.commit-card:nth-child(3) { animation-delay: calc(var(--content-delay, 0ms) + 240ms); }
	.commit-card:nth-child(4) { animation-delay: calc(var(--content-delay, 0ms) + 320ms); }
	.commit-card:nth-child(5) { animation-delay: calc(var(--content-delay, 0ms) + 400ms); }
	.commit-card:nth-child(6) { animation-delay: calc(var(--content-delay, 0ms) + 480ms); }
	.commit-card:nth-child(7) { animation-delay: calc(var(--content-delay, 0ms) + 560ms); }
	.commit-card:nth-child(8) { animation-delay: calc(var(--content-delay, 0ms) + 640ms); }
	.commit-card:nth-child(9) { animation-delay: calc(var(--content-delay, 0ms) + 720ms); }
	.commit-card:nth-child(10) { animation-delay: calc(var(--content-delay, 0ms) + 800ms); }
	.commit-card:nth-child(11) { animation-delay: calc(var(--content-delay, 0ms) + 880ms); }
	.commit-card:nth-child(12) { animation-delay: calc(var(--content-delay, 0ms) + 960ms); }

	/* ========== H1 Tags 标题样式 ========== */
	.commit-card :global(h1.commit-tag-title),
	.commit-card :global(h1[data-tag-title]) {
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--primary);
		margin: 0 0 0.5rem 0;
		padding: 0.25rem 0;
		line-height: 1.4;
		letter-spacing: -0.01em;
		overflow-wrap: break-word;
		word-wrap: break-word;
		word-break: break-word;
		border-left: 3px solid var(--primary);
		padding-left: 0.75rem;
		animation: titleSlideIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
		opacity: 0;
		transform: translateX(-20px);
	}

	@keyframes titleSlideIn {
		0% {
			opacity: 0;
			transform: translateX(-20px);
		}
		100% {
			opacity: 1;
			transform: translateX(0);
		}
	}

	/* 标题级联延迟 */
	.commit-card:nth-child(1) :global(h1.commit-tag-title),
	.commit-card:nth-child(1) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 150ms); }
	.commit-card:nth-child(2) :global(h1.commit-tag-title),
	.commit-card:nth-child(2) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 230ms); }
	.commit-card:nth-child(3) :global(h1.commit-tag-title),
	.commit-card:nth-child(3) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 310ms); }
	.commit-card:nth-child(4) :global(h1.commit-tag-title),
	.commit-card:nth-child(4) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 390ms); }
	.commit-card:nth-child(5) :global(h1.commit-tag-title),
	.commit-card:nth-child(5) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 470ms); }
	.commit-card:nth-child(6) :global(h1.commit-tag-title),
	.commit-card:nth-child(6) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 550ms); }
	.commit-card:nth-child(7) :global(h1.commit-tag-title),
	.commit-card:nth-child(7) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 630ms); }
	.commit-card:nth-child(8) :global(h1.commit-tag-title),
	.commit-card:nth-child(8) :global(h1[data-tag-title]) { animation-delay: calc(var(--content-delay, 0ms) + 710ms); }

	/* ========== H3 提交信息样式 ========== */
	.commit-card :global(h3) {
		overflow-wrap: break-word;
		word-wrap: break-word;
		word-break: break-word;
		max-width: 100%;
	}

	.commit-card :global(h3 p) {
		margin: 0;
		line-height: 1.6;
	}

	.commit-card :global(h3 code) {
		background-color: var(--btn-regular-bg);
		color: var(--btn-content);
		padding: 0.125rem 0.375rem;
		border-radius: 0.25rem;
		font-size: 0.75rem;
		font-weight: 500;
		font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
	}

	/* ========== Git 树状线样式 ========== */
	.git-tree-line {
		position: relative;
		overflow: visible;
	}

	.tree-line-vertical {
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* 节点样式 */
	.tree-node {
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 0 0 0 transparent;
		animation: nodePopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
		opacity: 0;
		transform: scale(0);
	}

	@keyframes nodePopIn {
		0% {
			opacity: 0;
			transform: scale(0);
		}
		70% {
			transform: scale(1.2);
		}
		100% {
			opacity: 1;
			transform: scale(1);
		}
	}

	/* 节点级联延迟 */
	.commit-card:nth-child(1) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 200ms); }
	.commit-card:nth-child(2) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 280ms); }
	.commit-card:nth-child(3) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 360ms); }
	.commit-card:nth-child(4) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 440ms); }
	.commit-card:nth-child(5) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 520ms); }
	.commit-card:nth-child(6) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 600ms); }
	.commit-card:nth-child(7) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 680ms); }
	.commit-card:nth-child(8) .tree-node { animation-delay: calc(var(--content-delay, 0ms) + 760ms); }

	.tree-node:hover {
		transform: scale(1.15);
		box-shadow: 0 0 0 4px color-mix(in oklch, var(--primary) 20%, transparent);
	}

	/* 最新节点脉冲动画 */
	@keyframes pulse-ring {
		0% {
			box-shadow: 0 0 0 0 color-mix(in oklch, var(--primary) 40%, transparent);
		}
		70% {
			box-shadow: 0 0 0 8px color-mix(in oklch, var(--primary) 0%, transparent);
		}
		100% {
			box-shadow: 0 0 0 0 color-mix(in oklch, var(--primary) 0%, transparent);
		}
	}

	/* ========== 卡片悬停效果 ========== */
	.commit-card {
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.commit-card:hover {
		transform: translateX(4px);
	}

	/* ========== 响应式设计 ========== */
	@media (max-width: 640px) {
		.commit-card :global(h3) {
			font-size: 0.875rem;
		}

		.commit-card :global(h1.commit-tag-title),
		.commit-card :global(h1[data-tag-title]) {
			font-size: 1.125rem;
			padding-left: 0.5rem;
		}

		.commit-card {
			animation: cascadeIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
		}
	}

	/* ========== 无障碍支持 ========== */
	@media (prefers-reduced-motion: reduce) {
		.commit-card {
			animation: none;
			opacity: 1;
			transform: none;
		}

		.tree-node,
		.tree-line-vertical,
		.commit-card {
			transition: none;
		}
	}
</style>
