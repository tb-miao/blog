---
import { siteConfig } from "@/config";

const perfConfig = siteConfig.performanceMonitor;

if (!perfConfig?.enable) {
	return null;
}
---

<div id="performance-monitor" class="performance-monitor hidden lg:block">
	<div class="perf-panel">
		<div class="perf-header">
			<svg class="perf-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
			</svg>
			<span class="perf-title">性能监控</span>
		</div>
		<div class="perf-content">
			{perfConfig.showLoadTime && (
				<div class="perf-item">
					<span class="perf-label">加载时间</span>
					<span class="perf-value" id="perf-load-time">--</span>
				</div>
			)}
			{perfConfig.showMemoryUsage && (
				<div class="perf-item">
					<span class="perf-label">内存占用</span>
					<span class="perf-value" id="perf-memory">--</span>
				</div>
			)}
		</div>
	</div>
</div>

<script is:inline>
	(function() {
		const LOG_PREFIX = '[PerformanceMonitor]';
		const DEBUG = false;
		const LOG_THROTTLE_MS = 1000;

		const loggedWarnings = new Set();
		const lastLogTime = new Map();
		const logDebounceTimers = new Map();

		function log(...args) {
			if (!DEBUG) return;
			
			const key = args.join(' ');
			const now = Date.now();
			const lastTime = lastLogTime.get(key) || 0;
			
			if (now - lastTime < LOG_THROTTLE_MS) {
				return;
			}
			
			lastLogTime.set(key, now);
			console.log(LOG_PREFIX, ...args);
		}

		function logOnce(...args) {
			if (!DEBUG) return;
			
			const key = args.join(' ');
			if (loggedWarnings.has(key)) {
				return;
			}
			
			loggedWarnings.add(key);
			console.log(LOG_PREFIX, ...args);
		}

		function warn(...args) {
			if (!DEBUG) return;
			
			const key = args.join(' ');
			if (loggedWarnings.has(key)) {
				return;
			}
			
			loggedWarnings.add(key);
			console.warn(LOG_PREFIX, ...args);
		}

		function error(...args) {
			if (!DEBUG) return;
			
			const key = args.join(' ');
			const now = Date.now();
			const lastTime = lastLogTime.get(key) || 0;
			
			if (now - lastTime < LOG_THROTTLE_MS * 5) {
				return;
			}
			
			lastLogTime.set(key, now);
			console.error(LOG_PREFIX, ...args);
		}

		function logDebounced(type, fn, ...args) {
			if (!DEBUG) return;
			
			if (logDebounceTimers.has(type)) {
				clearTimeout(logDebounceTimers.get(type));
			}
			
			logDebounceTimers.set(type, setTimeout(() => {
				fn(...args);
				logDebounceTimers.delete(type);
			}, 50));
		}

		const perfMonitor = document.getElementById('performance-monitor');
		if (!perfMonitor) {
			warn('组件未找到，跳过初始化');
			return;
		}

		logOnce('组件初始化');

		let updateTimer = null;
		let isCleanup = false;
		let updateCount = 0;

		function updatePerformance() {
			if (isCleanup) {
				return;
			}

			const loadTimeEl = document.getElementById('perf-load-time');
			const memoryEl = document.getElementById('perf-memory');

			if (loadTimeEl && window.performance && window.performance.timing) {
				const timing = window.performance.timing;
				const loadTime = timing.loadEventEnd - timing.navigationStart;
				if (loadTime > 0) {
					loadTimeEl.textContent = loadTime + 'ms';
					updateCount++;
					logDebounced('update', log, '更新 #%d: 加载时间 %dms', updateCount, loadTime);
				}
			} else if (!loadTimeEl) {
				warn('加载时间元素未找到');
			}

			if (memoryEl && window.performance && window.performance.memory) {
				const memory = window.performance.memory;
				const usedMB = (memory.usedJSHeapSize / 1024 / 1024).toFixed(2);
				const totalMB = (memory.totalJSHeapSize / 1024 / 1024).toFixed(2);
				memoryEl.textContent = `${usedMB}MB / ${totalMB}MB`;
				logDebounced('memory', log, '内存使用：%sMB / %sMB', usedMB, totalMB);
			} else if (memoryEl) {
				warn('浏览器不支持内存 API');
			} else {
				warn('内存元素未找到');
			}
		}

		function scheduleUpdate() {
			if (isCleanup) {
				return;
			}
			if (updateTimer) {
				clearTimeout(updateTimer);
			}
			updateTimer = setTimeout(updatePerformance, 100);
		}

		function loadHandler() {
			logOnce('页面加载完成');
			scheduleUpdate();
		}

		function popstateHandler() {
			log('路由变化');
			scheduleUpdate();
		}

		function swupHandler() {
			log('Swup 页面切换');
			scheduleUpdate();
		}

		window.addEventListener('load', loadHandler, { passive: true });
		window.addEventListener('popstate', popstateHandler, { passive: true });
		logOnce('事件监听器已注册');

		let swupCleanup = null;
		if (typeof window.swup !== 'undefined' && window.swup.hooks) {
			window.swup.hooks.on('content:replace', swupHandler);
			logOnce('Swup 钩子已注册');
			swupCleanup = function() {
				if (window.swup && window.swup.hooks) {
					window.swup.hooks.off('content:replace', swupHandler);
				}
			};
		} else {
			warn('Swup 未启用');
		}

		function cleanup() {
			if (isCleanup) {
				return;
			}
			isCleanup = true;
			log('清理资源...');

			if (updateTimer) {
				clearTimeout(updateTimer);
				updateTimer = null;
			}

			logDebounceTimers.forEach((timer) => clearTimeout(timer));
			logDebounceTimers.clear();

			window.removeEventListener('load', loadHandler);
			window.removeEventListener('popstate', popstateHandler);

			if (swupCleanup) {
				swupCleanup();
				swupCleanup = null;
			}

			log('清理完成');
		}

		if (typeof window.swup !== 'undefined' && window.swup.hooks) {
			window.swup.hooks.on('page:view', function() {
				const currentMonitor = document.getElementById('performance-monitor');
				if (!currentMonitor) {
					log('组件已移除，执行清理');
					cleanup();
				}
			});
		}

		window.addEventListener('beforeunload', cleanup, { passive: true });

		const observer = new MutationObserver(function(mutations) {
			for (let i = 0; i < mutations.length; i++) {
				if (!document.contains(perfMonitor)) {
					log('检测到组件移除');
					cleanup();
					observer.disconnect();
					break;
				}
			}
		});

		observer.observe(document.body, { childList: true, subtree: true });
		logOnce('监控器已启动');
	})();
</script>

<style>
	.performance-monitor {
		position: fixed;
		left: 1rem;
		bottom: 5rem;
		z-index: 999;
		pointer-events: auto;
		animation: perf-slide-in 0.4s var(--ease-standard) forwards;
	}

	@keyframes perf-slide-in {
		from {
			opacity: 0;
			transform: translateX(-20px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	.perf-panel {
		background: var(--card-bg-transparent);
		backdrop-filter: blur(var(--blur-lg)) saturate(180%);
		-webkit-backdrop-filter: blur(var(--blur-lg)) saturate(180%);
		border-radius: var(--radius-xl);
		padding: 0.875rem 1.125rem;
		min-width: 200px;
		box-shadow:
			var(--shadow-md),
			0 0 0 1px rgba(255, 255, 255, 0.05) inset;
		border: 1px solid var(--line-divider);
		transition: all 0.3s var(--ease-standard);
		font-family: var(--font-sans);
	}

	.perf-panel:hover {
		box-shadow:
			var(--shadow-lg),
			0 0 0 1px rgba(255, 255, 255, 0.08) inset;
		transform: translateY(-2px);
	}

	.perf-header {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		margin-bottom: 0.625rem;
		padding-bottom: 0.625rem;
		border-bottom: 1px solid var(--line-divider);
	}

	.perf-icon {
		width: 1.125rem;
		height: 1.125rem;
		color: var(--primary);
		filter: drop-shadow(0 0 6px var(--primary) / 0.3);
	}

	.perf-title {
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--content-meta);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-family: var(--font-sans);
	}

	.perf-content {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.perf-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.25rem 0;
		border-radius: var(--radius-md);
		transition: background-color 0.2s var(--ease-standard);
	}

	.perf-item:hover {
		background-color: var(--btn-plain-bg-hover);
		padding-left: 0.5rem;
		padding-right: 0.5rem;
		margin: 0 -0.25rem;
	}

	.perf-label {
		font-size: 0.75rem;
		color: var(--content-meta);
		font-family: var(--font-sans);
		font-weight: 400;
	}

	.perf-value {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--primary);
		font-family: var(--font-sans);
		letter-spacing: 0.02em;
	}

	@media (max-width: 1023px) {
		.performance-monitor {
			display: none !important;
		}
	}
</style>
